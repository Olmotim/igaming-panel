// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  AGENT
  SUPERVISOR
  ADMIN
}

enum Department {
  KYC
  PAYMENTS
  RISK
  SUPPORT
  OPERATIONS
}

enum PlayerStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  SELF_EXCLUDED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum KycLevel {
  NONE
  TIER_1
  TIER_2
  TIER_3
}

enum IdDocStatus {
  NOT_REQUESTED
  PENDING
  APPROVED
  REJECTED
}

enum ProofDocStatus {
  NOT_REQUESTED
  PENDING
  VERIFIED
  REJECTED
}

enum PepStatus {
  NOT_PEP
  PEP
  UNDER_REVIEW
}

enum PaymentType {
  DEPOSIT
  WITHDRAWAL
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BonusType {
  DEPOSIT
  FREE_SPINS
  CASHBACK
  NO_DEPOSIT
}

enum BonusStatus {
  ACTIVE
  CLAIMED
  CANCELLED
  EXPIRED
}

enum RGLimitType {
  DEPOSIT_LIMIT
  SESSION_LIMIT
  COOL_OFF
  SELF_EXCLUSION
  REALITY_CHECK
}

enum RGLimitPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum RGLimitStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_INFO
  RESOLVED
  CLOSED
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  password     String
  role         Role       @default(AGENT)
  department   Department?
  refreshToken String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workspaces      WorkspaceMember[]
  tasks           Task[]
  notes           PlayerNote[]
  ticketsCreated  Ticket[]        @relation("TicketCreatedBy")
  ticketsAssigned Ticket[]        @relation("TicketAssignedTo")
  ticketComments  TicketComment[]
  bonusesGranted  PlayerBonus[]
  kycReviews        PlayerKYC[]
}

model Workspace {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   WorkspaceMember[]
  tasks     Task[]
}

model WorkspaceMember {
  id          Int       @id @default(autoincrement())
  role        String    @default("member")
  joinedAt    DateTime  @default(now())

  userId      Int
  workspaceId Int

  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId Int
  assignedTo  Int?

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  assignee    User?     @relation(fields: [assignedTo], references: [id])
}

model Player {
  id                    Int      @id @default(autoincrement())

  // Datos básicos
  email                 String   @unique
  firstName             String   @default("")
  lastName              String   @default("")
  phone                 String?
  dateOfBirth           DateTime?
  gender                String?
  nationality           String?
  country               String?
  city                  String?
  address               String?
  language              String?  @default("es")
  registrationChannel   String?  @default("web")

  // Estado de cuenta
  status                PlayerStatus @default(PENDING_VERIFICATION)
  lastLogin             DateTime?
  verifiedAt            DateTime?

  // Balance
  realBalance           Float    @default(0)
  bonusBalance          Float    @default(0)

  // Estados independientes
  canDeposit            Boolean  @default(true)
  canWithdraw           Boolean  @default(true)
  canBet                Boolean  @default(true)
  canReceiveBonus       Boolean  @default(true)
  canLogin              Boolean  @default(true)

  // Tags
  tags                  String[] @default([])

  // AML/Risk
  riskLevel             RiskLevel @default(LOW)
  isPEP                 Boolean  @default(false)
  sofVerified           Boolean  @default(false)
  riskNotes             String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  notes                 PlayerNote[]
  tickets               Ticket[]
  kyc                   PlayerKYC?
  payments              PlayerPayment[]
  bonuses               PlayerBonus[]
  rgLimits              PlayerRGLimit[]
  loginHistory          PlayerLoginHistory[]

}

model PlayerNote {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  playerId  Int
  authorId  Int

  player    Player   @relation(fields: [playerId], references: [id], onDelete: Restrict)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([playerId])
  @@index([authorId])
}

model PlayerKYC {
  id                    Int      @id @default(autoincrement())

  // Nivel de verificación
  kycLevel              KycLevel @default(NONE)

  // Documento de identidad
  idDocType             String?
  idDocNumber           String?
  idDocExpiry           DateTime?
  idDocIssuingCountry   String?
  idDocStatus           IdDocStatus @default(NOT_REQUESTED)
  idDocUrl              String?

  // Proof of Address
  poaDocType            String?
  poaDocStatus          ProofDocStatus @default(NOT_REQUESTED)
  poaDocUrl             String?

  // Source of Funds
  sofDocStatus          ProofDocStatus @default(NOT_REQUESTED)
  sofDocUrl             String?
  sofDescription        String?

  // PEP
  pepStatus             PepStatus @default(NOT_PEP)
  pepNotes              String?

  // Auditoría
  reviewedAt            DateTime?
  reviewedById          Int?
  reviewedBy            User?    @relation(fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  playerId              Int      @unique
  player                Player   @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@index([reviewedById])
}

model PlayerPayment {
  id              Int      @id @default(autoincrement())
  type            PaymentType
  amount          Float
  currency        String   @default("EUR")
  status          PaymentStatus @default(PENDING)
  paymentMethod   String?
  accountNumber   String?
  reference       String?
  notes           String?
  processedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  playerId        Int
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@index([playerId])
}

model PlayerBonus {
  id                  Int      @id @default(autoincrement())
  type                BonusType
  description         String?
  amount              Float
  wagering            Float    @default(0)
  wageringCompleted   Float    @default(0)
  maxWinAmount        Float?
  status              BonusStatus @default(ACTIVE)
  expiresAt           DateTime?
  claimedAt           DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  playerId            Int
  grantedById         Int
  player              Player   @relation(fields: [playerId], references: [id], onDelete: Restrict)
  grantedBy           User     @relation(fields: [grantedById], references: [id], onDelete: Restrict)

  @@index([playerId])
  @@index([grantedById])
}

model PlayerRGLimit {
  id              Int      @id @default(autoincrement())
  type            RGLimitType
  period          RGLimitPeriod?
  amount          Float?
  duration        Int?
  status          RGLimitStatus @default(ACTIVE)
  requestedAt     DateTime?
  startDate       DateTime @default(now())
  endDate         DateTime?
  coolingOffUntil DateTime?
  excludedUntil   DateTime?
  therapyFlag     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  playerId        Int
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@index([playerId])
}

model PlayerLoginHistory {
  id          Int      @id @default(autoincrement())
  ip          String?
  device      String?
  browser     String?
  country     String?
  status      String   @default("SUCCESS")

  createdAt   DateTime @default(now())

  playerId    Int
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@index([playerId])
}

model Ticket {
  id           Int            @id @default(autoincrement())
  title        String
  description  String
  priority     TicketPriority @default(MEDIUM)
  status       TicketStatus   @default(OPEN)
  department   Department
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  createdById  Int
  assignedToId Int?
  playerId     Int?

  createdBy    User      @relation("TicketCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo   User?     @relation("TicketAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  player       Player?   @relation(fields: [playerId], references: [id], onDelete: SetNull)
  comments     TicketComment[]

  @@index([playerId])
  @@index([assignedToId])
  @@index([createdById])
}

model TicketComment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  ticketId  Int
  authorId  Int

  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([ticketId])
  @@index([authorId])
}
